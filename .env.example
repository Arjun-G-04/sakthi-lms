# Local SQLite database path (default: dev.db)
DATABASE_URL="dev.db"

# Turso Cloud Database connection URL (for production/Vercel)
# Format: libsql://your-db-name-your-username.turso.io
# Leave blank for local file-based development
TURSO_CONNECTION_URL=""

# Turso Cloud Database Auth Token (for production/Vercel)
# Leave blank for local file-based development
TURSO_AUTH_TOKEN=""
